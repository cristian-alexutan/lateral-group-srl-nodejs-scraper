{
  "name": "scraper-lateral-ro",
  "version": "1.0.0",
  "description": "Web scraper pentru a aduce locurile de munca de la Lateral Group in platforma peviitor.ro",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "scrape": "node --no-deprecation index.js",
    "test": "node --no-deprecation --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:unit": "node --no-deprecation --experimental-vm-modules ./node_modules/jest/bin/jest.js --testPathPattern=unit",
    "test:integration": "node --no-deprecation --experimental-vm-modules ./node_modules/jest/bin/jest.js --testPathPattern=integration",
    "test:e2e": "node --no-deprecation --experimental-vm-modules ./node_modules/jest/bin/jest.js --testPathPattern=e2e"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.5.0"
  }
}
